# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# SQLite
*.db
*.sqllite
*.sqllite3

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/

# Local Codex/test caches
.appdata/
.gocache/
.gocache-test/
.gomodcache/
.gotelemetry/
.grades-home/
.localappdata/
.tmp-align-home/

# Local generated files
roster_setup.csv
categories_setup.csv
grades-test-size.exe
dist/
.tmp-study-report.docx
study-reports/
excel-reports/
data/
test-data/
passwords.txt
*.bak

# Grade templates and data files
*.xls
*.xlsx

# Generated reports
By Mr Popovici.docx
By Mr Popovici.pdf

# Local-only scripts
restart-portal.txt

# Secrets
.jwt-secret*
.env

# Python cache
__pycache__/
*.pyc

# Node.js
node_modules/
